# ---- Football-Data.org API ----
# Get a free key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# ---- cPanel MySQL (remote) ----
# In cPanel: Remote MySQL → add your app server IP to Access Hosts.
DB_HOST=your-cpanel-host.com
DB_PORT=3306
DB_USER=cpaneluser_kickoff
DB_PASSWORD=change_me
DB_NAME=cpaneluser_kickoff

# ---- Admin dashboard (PHP backend at api-php/) ----
ADMIN_EMAIL=you@example.com
# Generate with:  php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
ADMIN_PASSWORD_HASH=$2y$10$replace_me
# 32+ random chars used to sign admin login tokens
SESSION_SECRET=change_me_to_a_long_random_string
# Public URL prefix for uploaded cover images
UPLOADS_URL=https://your-site.com/api-php/uploads

# ---- Frontend build-time ----
# Point the React app at your deployed PHP API. Leave empty to keep the
# admin dashboard running in preview/mock mode (localStorage only).
VITE_API_BASE_URL=
